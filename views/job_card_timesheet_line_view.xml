<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="job_card_timesheet_line_view_list" model="ir.ui.view">
         <field name="name">job.card.timesheet.line.view.list</field>
         <field name="model">job.card.timesheet.line</field>
         <field name="arch" type="xml">
             <list string="Timesheet">
                <field name="job_card_id"/>
                <field name="work_order_id"/>
                <field name="machanics_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="hours"/>
                <field name="labor_cost"/>
             </list>
         </field>
    </record>

    <record id='job_card_timesheet_line_view_form' model='ir.ui.view'>
        <field name="name">job.card.timesheet.line.view.form</field>
        <field name="model">job.card.timesheet.line</field>
        <field name="arch" type="xml">

            <form>
                <sheet>

                    <div class="oe_title">
                        <label for="work_order_id"/>
                        <h1>
                            <field name="work_order_id"/>
                        </h1>
                    </div>


                    <group>

                        <group string="Work Details">
                            <field name="job_card_id"
                                   options="{'no_open': True}"/>

                            <field name="work_order_id"
                                   options="{'no_open': True}"/>

                            <field name="machanics_id"/>
                        </group>


                        <group string="Time And Cost">
                            <field name="end_time"/>

                            <field name="hours"/>

                            <field name="labor_cost"
                                   readonly="1"/>
                        </group>

                    </group>


                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

    <record id="job_card_timesheet_line_view_search" model="ir.ui.view">
        <field name="name">job.card.timesheet.line.view.search</field>
        <field name="model">job.card.timesheet.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="job_card_id"/>
                <field name="work_order_id"/>
                <field name="machanics_id"/>
                <field name="end_time"/>
                <field name="hours"/>
                <field name="labor_cost"/>
            </search>
        </field>
    </record>

    <record id="action_job_card_timesheet_line" model="ir.actions.act_window">
        <field name="name">Job Card Timesheet</field>
        <field name="res_model">job.card.timesheet.line</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Job card Timesheet.
            </p>
        </field>
    </record>
</odoo>