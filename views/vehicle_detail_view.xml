<?xml version ="1.0" encoding = "utf-8"?>
<odoo>
	<record id = "vehicle_detail_list_view" model = "ir.ui.view">
		<field name = "name">vehicle.detail.list.view</field>
		<field name="model">vehicle.detail</field>
		<field name="arch" type ="xml">
			<list>
				<field name ="name"/>
				<field name = "partner_id"/>
				<field name = "vehicle_type"/>
				<field name = "fuel_type"/>
			</list>
		</field>
	</record>

	<record id = "vehicle_detail_form_view" model = "ir.ui.view">
		<field name = "name">vehicle.detail.form.view</field>
		<field name = "model">vehicle.detail</field>
		<field name = "arch" type = "xml">
			<form>
				<sheet>
                    <field name="image_128" widget='image' class="oe_avatar"/>
					<div class="oe_title">
                        <label for="model_id"/>
                        <h1>
                            <field name="model_id" placeholder="e.g. Model S" class="w-100" required = "1"/>
                        </h1>
                        <label for="name"/>
                        <h2>
                            <field name="name" class="oe_inline" placeholder="e.g. GJ-27-AC-9651" required = "1"/>
                        </h2>
                    </div>
					<group>
						<!-- <field name = "name"/>
						<field name = "model_id"/>-->
						<group string = "Vehicle">
							<field name = "mack_id"/> 
							<field name = "vehicle_type"/>
							<field name = "model_year"/>
							<field name = "fuel_type"/>
							<field name = "transmission"/>
							<field name = "color"/>
							<field name = "varient"/>
						</group>
						<group string = "Customer">
							<field name = "partner_id"/>
							<field name = "mobile_number" force_save = "1"/>
							<field name = "email" force_save = "1"/>
							<field name = "address"/>
						</group>
					</group>
				</sheet>
			</form>
		</field>
	</record>


	<record id = "vehicle_detail_search_view" model = "ir.ui.view">
		<field name = "name">vehicle.detail.search.view</field>
		<field name = "model">vehicle.detail</field>
		<field name = "arch" type = "xml">
			<search>
				<field name = "name"/>
				<field name = "model_id"/>
				<field name = "mack_id"/>
				<field name = "vehicle_type"/>
				<field name = "model_year"/>
				<field name = "fuel_type"/>
				<field name = "transmission"/>
				<field name = "color"/>
				<field name = "partner_id"/>
				<field name = "mobile_number"/>
				<field name = "email"/>
				<field name = "address"/>
			</search>
		</field>
	</record>


	<record id = "action_vehicle_detail" model = "ir.actions.act_window">
		<field name = "name">Vehicle Detail</field>
		<field name = "res_model">vehicle.detail</field>
		<field name = "view_mode">list,form</field>
		<field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Vehicle Detail.
            </p><p>
                Click on Create to add a new vehicle details like Vehicle number, vehicle color, etc.
            </p>
        </field>
    </record>

</odoo>