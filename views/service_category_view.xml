<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="service_category_view_list" model="ir.ui.view">
         <field name="name">service.category.view.list</field>
         <field name="model">service.category</field>
         <field name="arch" type="xml">
             <list string="Service Category">
             	<field name="name"/>
             </list>
         </field>
    </record>

    <record id='service_category_view_form' model='ir.ui.view'>
        <field name="name">service.category.view.form</field>
        <field name="model">service.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="checklist_id"/>
                        <field name ="service_type_ids">
                            <list editable = "bottom">
                                <field name = "name"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="service_category_view_search" model="ir.ui.view">
        <field name="name">service.category.view.search</field>
        <field name="model">service.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_service_category" model="ir.actions.act_window">
        <field name="name">Service Category</field>
        <field name="res_model">service.category</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Service Category.
            </p><p>
                Organize services into categories to simplify service management, classification, and reporting.
            </p>
        </field>
    </record>
</odoo>