<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id = "product_template_only_form_view_inherited_service" model = "ir.ui.view">
        <field name ="name">product.template.service.package</field>
        <field name = "model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name = "arch" type ="xml">
            <xpath expr="//field[@name='purchase_ok']" position="before">
                <field name = "is_service_package"/>
                <label for="is_service_package"/>
            </xpath>

            <xpath expr="//group[1]" position="inside">
                <group invisible = "not is_service_package">
                    <label for="duration" />
                    <div class="o_row">
                        <field name="duration"/>
                        <span class="oe_inline">Month</span>
                    </div>
                </group>
            </xpath>
        </field>
    </record>

	<record id ='product_template_inherited_action' model='ir.actions.act_window'>
		<field name="name">Vehical Parts</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{"search_default_filter_to_sell":1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Vehical Parts
            </p><p>
                You must define a product for everything you sell or purchase,
                whether it's a storable product, a consumable or a service.
            </p>
        </field>
	</record>
</odoo>