<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="job_card_vehicle_spare_parts_view_list" model="ir.ui.view">
         <field name="name">job.card.vehicle.spare.parts.view.list</field>
         <field name="model">job.card.vehicle.spare.parts</field>
         <field name="arch" type="xml">
             <list string="Service Charge Item">
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="subtotal"/>
                <field name="job_card_id"/>
             </list>
         </field>
    </record>

    <record id='job_card_vehicle_spare_parts_view_form' model='ir.ui.view'>
        <field name="name">job.card.vehicle.spare.parts.view.form</field>
        <field name="model">job.card.vehicle.spare.parts</field>
        <field name="arch" type="xml">

            <form>
                <sheet>

                    <div class="oe_title">
                        <label for="product_id"/>
                        <h1>
                            <field name="product_id"
                                   domain="[('type','=','consu')]"/>
                        </h1>
                    </div>


                    <group>

                        <group string="Part Details">
                            <field name="job_card_id"
                                   options="{'no_open': True}"/>

                            <field name="product_id"
                                   domain="[('type','=','consu')]"/>

                            <field name="uom_id"/>
                        </group>


                        <group string="Quantity And Pricing">
                            <field name="quantity"/>

                            <field name="unit_price"/>

                            <field name="subtotal"
                                   readonly="1"/>
                        </group>

                    </group>


                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

    <record id="job_card_vehicle_spare_parts_view_search" model="ir.ui.view">
        <field name="name">job.card.vehicle.spare.parts.view.search</field>
        <field name="model">job.card.vehicle.spare.parts</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id" domain="[('type','=','consu')]"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="subtotal"/>
                <field name="job_card_id"/>
            </search>
        </field>
    </record>

    <record id="action_job_card_vehicle_spare_parts" model="ir.actions.act_window">
        <field name="name">Job Card Vehicle Parts</field>
        <field name="res_model">job.card.vehicle.spare.parts</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Job card Vehicle Parts.
            </p>
        </field>
    </record>
</odoo>