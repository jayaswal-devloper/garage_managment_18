<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="service_type_view_list" model="ir.ui.view">
         <field name="name">service.type.view.list</field>
         <field name="model">service.type</field>
         <field name="arch" type="xml">
             <list string="Service Type">
             	<field name="name"/>
                <field name="service_category_id"/>
             </list>
         </field>
    </record>

    <record id='service_type_view_form' model='ir.ui.view'>
        <field name="name">service.type.view.form</field>
        <field name="model">service.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="service_category_id"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="service_type_view_search" model="ir.ui.view">
        <field name="name">service.type.view.search</field>
        <field name="model">service.type</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="service_category_id"/>
            </search>
        </field>
    </record>

    <record id="action_service_type" model="ir.actions.act_window">
        <field name="name">Service Type</field>
        <field name="res_model">service.type</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Service Type.
            </p><p>
                Categorize and manage specific services provided by your workshop.
            </p>
        </field>
    </record>
</odoo>