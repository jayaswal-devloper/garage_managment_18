<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="job_card_service_charge_line_view_list" model="ir.ui.view">
         <field name="name">job.card.service.charge.line.view.list</field>
         <field name="model">job.card.service.charge.line</field>
         <field name="arch" type="xml">
             <list string="Service Charge Item">
                <field name="job_card_id"/>
                <field name="product_id" domain="[('type','=','service')]"/>
                <field name="description"/>
                <field name="uom_id"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="subtotal"/>
             </list>
         </field>
    </record>

    <record id='job_card_service_charge_line_view_form' model='ir.ui.view'>
        <field name="name">job.card.service.charge.line.view.form</field>
        <field name="model">job.card.service.charge.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="job_card_id"/>
                        <field name="product_id" domain="[('type','=','service')]"/>
                        <field name="description"/>
                        <field name="uom_id"/>
                        <field name="quantity"/>
                        <field name="unit_price"/>
                        <field name="subtotal" force_save = "1" readonly = "1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="job_card_service_charge_line_view_search" model="ir.ui.view">
        <field name="name">job.card.service.charge.line.view.search</field>
        <field name="model">job.card.service.charge.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="job_card_id"/>
                <field name="product_id" domain="[('type','=','service')]"/>
                <field name="description"/>
                <field name="uom_id"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="subtotal"/>
            </search>
        </field>
    </record>

    <record id="action_job_card_service_charge_line" model="ir.actions.act_window">
        <field name="name">Job Card Service Charge Item</field>
        <field name="res_model">job.card.service.charge.line</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Job card Service charge Item.
            </p>
        </field>
    </record>
</odoo>