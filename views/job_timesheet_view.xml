<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="job_timesheet_view_list" model="ir.ui.view">
         <field name="name">job.timesheet.view.list</field>
         <field name="model">job.timesheet</field>
         <field name="arch" type="xml">
             <list string="Job Timesheet">
             	<field name="job_card_id"/>
             	<field name="work_order_id"/>
             	<field name="machanics_id"/>
             	<field name="hours"/>
             	<field name="labor_cost"/>
             </list>
         </field>
    </record>

    <record id='job_timesheet_view_form' model='ir.ui.view'>
        <field name="name">job.timesheet.view.form</field>
        <field name="model">job.timesheet</field>
        <field name="arch" type="xml">
            <form string="Job Timesheet">
                <sheet>

                <div class="oe_title">
                    <h1>
                        <field name="work_order_id" readonly="1"/>
                    </h1>
                </div>
                <group>
                    <group string="Reference Information">
                        <field name="job_card_id"/>
                        <field name="work_order_id"/>
                    </group>
                    <group string="Labor Details">
                        <field name="machanics_id"/>
                        <field name="hours"/>
                        <field name="labor_cost"/>
                    </group>
                </group>
            </sheet>
            <chatter/>
            </form>
        </field>
    </record>

    <record id="job_timesheet_view_search" model="ir.ui.view">
        <field name="name">job.timesheet.view.search</field>
        <field name="model">job.timesheet</field>
        <field name="arch" type="xml">
            <search>
                <field name="job_card_id"/>
                <field name="work_order_id"/>
                <field name="machanics_id"/>
                <field name="hours"/>
                <field name="labor_cost"/>
            </search>
        </field>
    </record>

    <record id="action_job_timesheet" model="ir.actions.act_window">
        <field name="name">Job Timesheet</field>
        <field name="res_model">job.timesheet</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Job Timesheet.
            </p><p>
                Record and track the time spent by technicians on each job card, including repairs, inspections, and maintenance tasks for accurate billing and performance analysis.
            </p>
        </field>
    </record>
</odoo>