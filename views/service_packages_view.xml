<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="service_packages_view_list" model="ir.ui.view">
        <field name="name">service.packages.view.list</field>
        <field name="model">service.packages</field>
        <field name="arch" type="xml">
            <list string="Service Packages">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="service_packages_view_form" model="ir.ui.view">
        <field name="name">service.packages.view.form</field>
        <field name="model">service.packages</field>
        <field name="arch" type="xml">
            <form string="Service Package">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name= "product_id" domain = "[('is_service_package','=',True)]"/>
                        <field name="service_category_id"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string = 'Benefit'>
                            <field name="service_package_line_ids">
                                <list> 
                                    <field name="product_id" domain="[('type','=','service')]"/>
                                    <field name="free_of_charge"/>
                                    <field name="discount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="service_packages_view_search" model="ir.ui.view">
        <field name="name">service.packages.view.search</field>
        <field name="model">service.packages</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
            </search>
        </field>
    </record>

    <record id="action_service_packages" model="ir.actions.act_window">
        <field name="name">Packages</field>
        <field name="res_model">service.packages</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="service_packages_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Service Package
            </p>
            <p>
                Define service packages by combining multiple services into a
                single offering for customers.
            </p>
        </field>
    </record>

</odoo>