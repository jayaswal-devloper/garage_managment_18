<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="job_card_checklist_line_view_list" model="ir.ui.view">
         <field name="name">job.card.checklist.line.view.list</field>
         <field name="model">job.card.checklist.line</field>
         <field name="arch" type="xml">
             <list string="Service Type">
                <field name="sequence"/>
                <field name="name"/>
                <field name="required"/>
                <field name="done"/>
                <field name="note"/>
                <field name="completed_by"/>
                <field name="completed_on"/>
             	<field name="job_card_id"/>
             </list>
         </field>
    </record>

    <record id='job_card_checklist_line_view_form' model='ir.ui.view'>
        <field name="name">job.card.checklist.line.view.form</field>
        <field name="model">job.card.checklist.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="job_card_id"/>
                            <field name="name"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name ="checklist_tmpl_id"/>
                        </group>
                        <group>
                            <field name="required"/>
                            <field name="completed_on"/>
                            <field name="note"/>
                        </group>
                        <group>
                            <field name="done"/>
                            <field name="completed_by"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="job_card_checklist_line_view_search" model="ir.ui.view">
        <field name="name">job.card.checklist.line.view.search</field>
        <field name="model">job.card.checklist.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="sequence"/>
                <field name="name"/>
                <field name="required"/>
                <field name="done"/>
                <field name="note"/>
                <field name="completed_by"/>
                <field name="completed_on"/>
                <field name="job_card_id"/>
            </search>
        </field>
    </record>

    <record id="action_job_card_checklist_line" model="ir.actions.act_window">
        <field name="name">Job Card Checklist line</field>
        <field name="res_model">job.card.checklist.line</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Job card checklist.
            </p>
        </field>
    </record>
</odoo>