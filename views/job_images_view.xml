<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="job_card_image_view_list" model="ir.ui.view">
         <field name="name">job.card.image.view.list</field>
         <field name="model">job.card.image</field>
         <field name="arch" type="xml">
             <list string="Service Category">
             	<field name="job_card_id"/>
                <field name = "name"/>
             </list>
         </field>
    </record>

    <record id='job_card_image_view_form' model='ir.ui.view'>
        <field name="name">job.card.image.view.form</field>
        <field name="model">job.card.image</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="job_card_id" readonly="1" options="{'no_open': True}"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920'}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="job_card_image_view_search" model="ir.ui.view">
        <field name="name">job.card.image.view.search</field>
        <field name="model">job.card.image</field>
        <field name="arch" type="xml">
            <search>
                <field name="job_card_id"/>
                <field name="image_1920"/>
                <!-- <field name ="description_image"/> -->
            </search>
        </field>
    </record>

    <record id="job_card_image_view_kanban" model="ir.ui.view">
        <field name="name">job.card.image.kanban</field>
        <field name="model">job.card.image</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="image_1920"/>
                <field name="name"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <img t-att-src="kanban_image(
                                'job.card.image',
                                'image_1920',
                                record.id.raw_value
                            )"
                            style="width:150px;height:150px;object-fit:cover;"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_job_card_image" model="ir.actions.act_window">
        <field name="name">Vehical Images</field>
        <field name="res_model">job.card.image</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a vehicle image.
            </p><p>
                Add a vehicle image for a any Dent in a Vehicle.
            </p>
        </field>
    </record>
</odoo>