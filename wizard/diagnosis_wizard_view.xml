<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id = "view_diagnosis_wizard_form" model = "ir.ui.view">
		<field name="name">diagnosis.wizard.form</field>
		<field name ="model">diagnosis.wizard</field>
		<field name="arch" type = "xml">
			<form>
				<group>
					<field name = "job_card_id" readonly = "1" force_save = "1" options = "{'no_open': '1'}"/>
					<field name = "diagnosis_detail"/>
					<field name = "machanics_id" readonly = "1" force_save = "1" options = "{'no_open': '1'}"/>
					<notebook>
						<page string = "Service Charge">
							<field name = "job_card_service_charge_line_ids">
								<list editable="bottom">
                                    <field name="product_id" domain="[('type','=','service')]"/>
                                    <field name="description"/>
                                    <field name="uom_id" options = "{'no_open': '1'}"/>
                                    <field name="quantity"/>
                                    <field name="unit_price" readonly = '1' force_save = "1"/>
                                    <field name="subtotal" readonly = '1' force_save = "1"/>
                                </list>
							</field>
							<field name = "job_card_vehicle_part_ids">
								<list editable="bottom">
                                    <field name="product_id" domain="[('type','=','consu')]"/>
                                    <field name="uom_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price" force_save = "1"/>
                                    <field name="subtotal" force_save = "1"/>
                                </list>
							</field>
						</page>
					</notebook>
					<footer>
                        <button name="action_confirm"
                                string="Confirm"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
				</group>
			</form>
		</field>

	</record>
</odoo>